# ─────────────────────────────────────────────────────────────
# KwanzaFlow AI — Variáveis de ambiente
# Copie este ficheiro para `.env.local` e preencha os valores.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua-anon-key"

# Apenas no servidor — NUNCA expor no frontend.
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"

# OpenAI — usado EXCLUSIVAMENTE no backend (Responses API)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4.1-mini"

# App
NEXT_PUBLIC_APP_NAME="KwanzaFlow"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Quando "true", a app corre com dados de demonstração (sem Supabase/OpenAI).
# Defina "false" depois de configurar as chaves para usar dados reais.
NEXT_PUBLIC_DEMO_MODE="true"
